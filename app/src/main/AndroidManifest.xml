<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.apkbuilderai">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!-- النشاط الرئيسي المحسن مع واجهة مستخدم كاملة -->
        <activity
            android:name=".ui.MainActivityEnhanced"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- النشاط الأصلي -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <!-- نشاط شفاف -->
        <activity
            android:name=".ui.TransparentActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- الخدمة التي تعمل في الخلفية -->
        <service
            android:name=".core.BackgroundService"
            android:enabled="true"
            android:exported="false" />

        <!-- Receiver لتشغيل الخدمة تلقائياً -->
        <receiver
            android:name=".core.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
        
    </application>

</manifest>
