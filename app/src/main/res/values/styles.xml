<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.AppCompat.Light.DarkActionBar" parent="android:Theme.Light">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_variant</item>
        <item name="android:colorAccent">@color/secondary</item>
        <item name="android:textColorPrimary">@color/on_background</item>
        <item name="android:textColorSecondary">@color/on_surface</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.AppCompat.Headline" parent="android:TextAppearance">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <style name="TextAppearance.AppCompat.Body1" parent="android:TextAppearance">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_background</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.AppCompat.Button" parent="android:Widget.Button">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:background">@color/primary</item>
        <item name="android:padding">12dp</item>
    </style>
</resources>
