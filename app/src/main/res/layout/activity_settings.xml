<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="الإعدادات"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Theme Setting -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="المظهر"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <Spinner
                android:id="@+id/theme_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Language Setting -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="لغة التطبيق"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <Spinner
                android:id="@+id/app_language_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Switches -->
            <CheckBox
                android:id="@+id/auto_detect_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="كشف اللغة تلقائياً"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/notifications_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="تفعيل الإشعارات"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/save_history_checkbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="حفظ سجل البناء"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/save_settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="حفظ الإعدادات"
        android:background="@color/primary"
        android:textColor="@color/on_primary" />

</LinearLayout>
